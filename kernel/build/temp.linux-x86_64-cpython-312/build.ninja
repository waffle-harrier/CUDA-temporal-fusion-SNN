ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda-13.2/bin/nvcc

cflags = -fno-strict-overflow -Wsign-compare -DNDEBUG -g -O3 -Wall -fPIC -I/home/guts/env/lib/python3.12/site-packages/torch/include -I/home/guts/env/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -I/usr/local/cuda-13.2/include -I/home/guts/env/single_gpu_testing/kernel/include -I/home/guts/env/include -I/home/guts/.pyenv/versions/3.12.0/include/python3.12 -c
post_cflags = -DTORCH_API_INCLUDE_EXTENSION_H -DTORCH_EXTENSION_NAME=temporal_fusion_kernel -std=c++17
cuda_cflags = -I/home/guts/env/lib/python3.12/site-packages/torch/include -I/home/guts/env/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -I/usr/local/cuda-13.2/include -I/home/guts/env/single_gpu_testing/kernel/include -I/home/guts/env/include -I/home/guts/.pyenv/versions/3.12.0/include/python3.12 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -DTORCH_API_INCLUDE_EXTENSION_H -DTORCH_EXTENSION_NAME=temporal_fusion_kernel -gencode=arch=compute_86,code=compute_86 -gencode=arch=compute_86,code=sm_86 -std=c++17
cuda_dlink_post_cflags = 
sycl_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc -MD -MF $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags







build /home/guts/env/single_gpu_testing/kernel/build/temp.linux-x86_64-cpython-312/src/lif_kernel.o: cuda_compile /home/guts/env/single_gpu_testing/kernel/src/lif_kernel.cu
build /home/guts/env/single_gpu_testing/kernel/build/temp.linux-x86_64-cpython-312/src/neuron.o: compile /home/guts/env/single_gpu_testing/kernel/src/neuron.cpp
build /home/guts/env/single_gpu_testing/kernel/build/temp.linux-x86_64-cpython-312/src/ternary_lif_kernel.o: cuda_compile /home/guts/env/single_gpu_testing/kernel/src/ternary_lif_kernel.cu








